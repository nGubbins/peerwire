{
  "name": "peerwire",
  "version": "0.1.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "relay": "node src/p2p-messenger/server.js",
    "build": "electron-builder",
    "test": "node --test"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.peerwire.app",
    "productName": "Peerwire Chat",
    "files": [
      "main.js",
      "src/p2p-messenger/**"
    ],
    "mac": {
      "target": "dmg",
      "identity": null
    },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" },
    "publish": {
      "provider": "github",
      "owner": "nGubbins",
      "repo": "peerwire"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
